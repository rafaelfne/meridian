# Database (Docker Compose)
POSTGRES_USER="user"
POSTGRES_PASSWORD="password"
POSTGRES_DB="domain_mapper"
POSTGRES_PORT=5432

# Prisma
DATABASE_URL="postgresql://user:password@localhost:5432/domain_mapper?schema=public"

# Auth.js
AUTH_SECRET="your-auth-secret-here"
AUTH_GITHUB_ID="your-github-oauth-app-id"
AUTH_GITHUB_SECRET="your-github-oauth-app-secret"

# App
NEXTAUTH_URL="http://localhost:3000"

# Field-level encryption (32-byte base64-encoded key: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
ENCRYPTION_KEY=""

# Cron job authentication (random secret string for protecting cron endpoints)
CRON_SECRET=""
