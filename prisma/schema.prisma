generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth.js Models ──────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  tokenVersion  Int       @default(0)
  accounts          Account[]
  sessions          Session[]
  workspaceMembers  WorkspaceMember[]
  documents         Document[]
  documentRevisions DocumentRevision[]
  statusOverrides   StatusOverride[]
  passwordResetTokens PasswordResetToken[]
  apiKeys           ApiKey[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
}

model ApiKey {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  keyHash     String
  keyPrefix   String
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator     User      @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([workspaceId])
}

// ── Workspace Models ────────────────────────────────────

enum WorkspaceRole {
  OWNER
  EDITOR
  VIEWER
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members            WorkspaceMember[]
  domains            Domain[]
  inventoryUploads   InventoryUpload[]
  datadogIntegration DatadogIntegration?
  products           Product[]
  statusPageConfig   StatusPageConfig?
  incidents          Incident[]
  statusOverrides    StatusOverride[]
  apiKeys            ApiKey[]
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole @default(VIEWER)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

// ── Domain Models ───────────────────────────────────────

enum SystemLayer {
  EDGE
  BUSINESS_LOGIC
  DATA_INFRA
}

model Domain {
  id          String    @id @default(cuid())
  name        String
  description String?
  workspaceId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  systems     System[]

  @@unique([workspaceId, name])
}

model System {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  purpose          String?
  language         String?
  framework        String?
  frameworkVersion  String?
  repositoryUrl    String?
  layer            SystemLayer?
  domainId         String
  domain           Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)
  inventoryRaw     Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  datadogStatus    DatadogMonitorStatus?

  services         Service[]
  databases        Database[]
  integrations     Integration[]
  messageTopics    MessageTopic[]
  packages         Package[]
  apiEndpoints     ApiEndpoint[]
  risks            Risk[]
  dependsOn        Dependency[] @relation("DependencySource")
  dependedBy       Dependency[] @relation("DependencyTarget")
  documents        Document[]
  products         ProductSystem[]
  features         FeatureSystem[]

  @@unique([domainId, name])
}

model Service {
  id                     String                @id @default(cuid())
  name                   String
  slug                   String
  type                   ServiceType
  systemId               String
  system                 System                @relation(fields: [systemId], references: [id], onDelete: Cascade)
  datadogServiceTag      String?
  datadogStatus          DatadogMonitorStatus?
  datadogStatusUpdatedAt DateTime?
  datadogMonitorIds      Json?

  @@unique([systemId, slug])
}

enum ServiceType {
  API
  WORKER
  CRONJOB
  BACKGROUND_SERVICE
}

model Database {
  id       String  @id @default(cuid())
  name     String
  provider String
  version  String?
  orm      String?
  tables   Json?
  systemId String
  system   System  @relation(fields: [systemId], references: [id], onDelete: Cascade)
}

model Integration {
  id           String          @id @default(cuid())
  name         String
  type         IntegrationType
  targetSystem String?
  url          String?
  protocol     String?
  systemId     String
  system       System          @relation(fields: [systemId], references: [id], onDelete: Cascade)
}

enum IntegrationType {
  HTTP_API
  DATABASE_DIRECT
  GRPC
  GRAPHQL
  SOAP
  FILE_TRANSFER
  OTHER
}

model MessageTopic {
  id       String        @id @default(cuid())
  name     String
  role     TopicRole
  broker   MessageBroker
  metadata Json?
  systemId String
  system   System        @relation(fields: [systemId], references: [id], onDelete: Cascade)
}

enum MessageBroker {
  KAFKA
  RABBITMQ
  SQS
  SNS
  OTHER
}

enum TopicRole {
  PRODUCER
  CONSUMER
  BOTH
}

model Package {
  id       String       @id @default(cuid())
  name     String
  version  String?
  scope    PackageScope
  systemId String
  system   System       @relation(fields: [systemId], references: [id], onDelete: Cascade)
}

enum PackageScope {
  INTERNAL
  OPEN_SOURCE
  TEST
}

model ApiEndpoint {
  id          String  @id @default(cuid())
  path        String
  method      String?
  description String?
  systemId    String
  system      System  @relation(fields: [systemId], references: [id], onDelete: Cascade)
}

model Risk {
  id          String   @id @default(cuid())
  title       String
  description String?
  severity    Severity
  systemId    String
  system      System   @relation(fields: [systemId], references: [id], onDelete: Cascade)
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Dependency {
  id        String         @id @default(cuid())
  sourceId  String
  targetId  String
  type      DependencyType
  label     String?
  metadata  Json?
  source    System         @relation("DependencySource", fields: [sourceId], references: [id], onDelete: Cascade)
  target    System         @relation("DependencyTarget", fields: [targetId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([sourceId, targetId, type, label])
}

enum DependencyType {
  HTTP_API
  KAFKA_TOPIC
  RABBITMQ_QUEUE
  SQS_QUEUE
  SHARED_DATABASE
  CROSS_DATABASE_QUERY
  SHARED_PACKAGE
  GRPC
  FILE_DEPENDENCY
}

model InventoryUpload {
  id           String       @id @default(cuid())
  filename     String
  status       UploadStatus @default(PENDING)
  systemsCount Int          @default(0)
  errors       Json?
  rawPayload   Json
  uploadedById String?
  workspaceId  String
  createdAt    DateTime     @default(now())
  processedAt  DateTime?

  workspace    Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  snapshot     GraphSnapshot?
}

enum UploadStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model GraphSnapshot {
  id          String          @id @default(cuid())
  uploadId    String          @unique
  upload      InventoryUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  nodesJson   Json
  edgesJson   Json
  systemCount Int
  edgeCount   Int
  createdAt   DateTime        @default(now())
}

// ── Documentation Models ────────────────────────────────

model Document {
  id          String   @id @default(cuid())
  title       String
  slug        String
  content     String   @db.Text
  systemId    String
  system      System   @relation(fields: [systemId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  revisions   DocumentRevision[]

  @@unique([systemId, slug])
}

model DocumentRevision {
  id         String   @id @default(cuid())
  content    String   @db.Text
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  createdAt  DateTime @default(now())
}

// ── Datadog Integration ───────────────────────────────

enum DatadogSite {
  DATADOGHQ_COM
  DATADOGHQ_EU
  US3_DATADOGHQ_COM
  US5_DATADOGHQ_COM
}

enum IntegrationStatus {
  CONNECTED
  INVALID
  REVOKED
}

enum DatadogMonitorStatus {
  OK
  WARN
  ALERT
  NO_DATA
  NOT_FOUND
}

model DatadogIntegration {
  id          String            @id @default(cuid())
  workspaceId String            @unique
  apiKey      String            @db.Text
  appKey      String            @db.Text
  site        DatadogSite
  status      IntegrationStatus @default(CONNECTED)
  connectedAt DateTime          @default(now())
  revokedAt   DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ── Product Models ──────────────────────────────────────

enum ProductTier {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String
  description String?
  tier        ProductTier @default(MEDIUM)
  workspaceId String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  systems     ProductSystem[]
  features    Feature[]
  statusPageProducts StatusPageProduct[]
  incidents   Incident[]

  @@unique([workspaceId, slug])
  @@unique([workspaceId, name])
}

model ProductSystem {
  id        String   @id @default(cuid())
  productId String
  systemId  String
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  system    System   @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@unique([productId, systemId])
}

model Feature {
  id          String   @id @default(cuid())
  name        String
  description String?
  productId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  systems     FeatureSystem[]
  statusPageFeatures StatusPageFeature[]
  incidents   Incident[]

  @@unique([productId, name])
}

model FeatureSystem {
  id        String   @id @default(cuid())
  featureId String
  systemId  String
  createdAt DateTime @default(now())

  feature   Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)
  system    System   @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@unique([featureId, systemId])
}

// ── Status Page Models ──────────────────────────────────

model StatusPageConfig {
  id            String   @id @default(cuid())
  workspaceId   String   @unique
  enabled       Boolean  @default(false)
  slug          String   @unique
  logoUrl       String?  @db.Text
  faviconUrl    String?  @db.Text
  primaryColor  String?
  pageTitle     String?
  hidePoweredBy Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  products    StatusPageProduct[]
}

model StatusPageProduct {
  id           String  @id @default(cuid())
  statusPageId String
  productId    String
  publicName   String
  visible      Boolean @default(true)
  displayOrder Int     @default(0)

  statusPage   StatusPageConfig    @relation(fields: [statusPageId], references: [id], onDelete: Cascade)
  product      Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  features     StatusPageFeature[]

  @@unique([statusPageId, productId])
}

model StatusPageFeature {
  id                  String  @id @default(cuid())
  statusPageProductId String
  featureId           String
  publicName          String
  visible             Boolean @default(true)
  displayOrder        Int     @default(0)

  statusPageProduct   StatusPageProduct @relation(fields: [statusPageProductId], references: [id], onDelete: Cascade)
  feature             Feature           @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([statusPageProductId, featureId])
}

// ── Incident History ────────────────────────────────────

enum IncidentStatus {
  DEGRADED
  OUTAGE
}

model Incident {
  id                String         @id @default(cuid())
  workspaceId       String
  affectedProductId String
  affectedFeatureId String?
  publicName        String
  status            IncidentStatus
  startedAt         DateTime       @default(now())
  resolvedAt        DateTime?
  durationMinutes   Int?
  auto              Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [affectedProductId], references: [id], onDelete: Cascade)
  feature   Feature?  @relation(fields: [affectedFeatureId], references: [id], onDelete: Cascade)

  @@index([workspaceId, startedAt])
  @@index([workspaceId, resolvedAt])
}

// ── Status Overrides ────────────────────────────────────

enum OverrideStatus {
  INVESTIGATING
  IDENTIFIED
  MONITORING
  RESOLVED
}

model StatusOverride {
  id          String         @id @default(cuid())
  workspaceId String
  targetType  String         // "product" | "feature"
  targetId    String         // Product.id or Feature.id
  status      OverrideStatus
  message     String?
  setBy       String
  expiresAt   DateTime
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [setBy], references: [id], onDelete: Cascade)

  @@index([workspaceId, targetType, targetId])
}
